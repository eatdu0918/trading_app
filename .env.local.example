# ─── Clerk Authentication ────────────────────────────────────────────────────
# 발급: https://dashboard.clerk.com → Create Application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (기본값 사용 가능, 필요 시 변경)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Neon Postgres (워치리스트 영속화) ────────────────────────────────────────
# 발급: https://neon.tech → New Project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── 초기화 명령어 ────────────────────────────────────────────────────────────
# 1. cp .env.local.example apps/web/.env.local
# 2. 위 값을 실제 키로 교체
# 3. pnpm --filter @trading-app/web db:push   (Drizzle 스키마 반영)
